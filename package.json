{
  "name": "cyber-news",
  "version": "0.1.0",
  "description": "Personal cybersecurity news dissector — Phase 1 (ingest + dedup + pre-filter)",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "ingest": "node --import tsx/esm src/ingest/run.ts",
    "migrate": "node --import tsx/esm scripts/migrate.ts",
    "test": "node --import tsx/esm --test tests/**/*.test.ts"
  },
  "dependencies": {
    "@libsql/client": "^0.15.0",
    "@mozilla/readability": "^0.6.0",
    "jsdom": "^25.0.0",
    "rss-parser": "^3.13.0",
    "yaml": "^2.6.0"
  },
  "devDependencies": {
    "@types/jsdom": "^21.1.7",
    "@types/node": "^22.7.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
